# API Keys
# Copy this file to .env and fill in your API keys

# ElevenLabs API Key (required for voice generation)
# Get your API key from https://beta.elevenlabs.io/subscription
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# OpenAI API Key (required for AI responses)
# Get your API key from https://platform.openai.com/account/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Stream Elements API Key (optional)
# If provided, will use Stream Elements for AI responses
# Get your API key from your Stream Elements dashboard
STREAMELEMENTS_API_KEY=your_streamelements_api_key_here
